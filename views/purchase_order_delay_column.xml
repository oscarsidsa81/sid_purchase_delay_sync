<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_purchase_order_line_tree_delay_custom" model="ir.ui.view">
        <field name="name">OV - Purchase Order Line Delay (decorations)</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="priority">16010</field>
        <field name="arch" type="xml">

            <!-- Clase propia para acotar CSS + decorations -->
            <xpath expr="//tree" position="attributes">
                <attribute name="class">decorated-po-lines</attribute>

                <!-- Odoo 15: estas decorations añaden clases decoration-* al <tr> -->
                <attribute name="decoration-muted">
                    sid_po_line_delay in ('1_week_del')
                </attribute>
                <attribute name="decoration-warning">
                    sid_po_line_delay == '2_week_del'
                </attribute>
                <attribute name="decoration-danger">
                    sid_po_line_delay in ('4_week_del','more_del')
                </attribute>
            </xpath>

            <!-- Asegura que el campo esté presente en el tree -->
            <xpath expr="//field[@name='order_id']" position="after">
                <field name="pending_line" optional="show"/>
                <field name="sid_po_line_delay" optional="show"/>
            </xpath>

            <!-- Negrita en el valor del campo (si tu tema lo respeta) -->
            <xpath expr="//field[@name='sid_po_line_delay']" position="attributes">
                <attribute name="decoration-bf">
                    sid_po_line_delay in ('1_week_del','2_week_del','4_week_del','more_del')
                </attribute>
            </xpath>
        </field>
    </record>

</odoo>
