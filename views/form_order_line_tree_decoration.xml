<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Purchase Order: columna de retraso en líneas (sid_po_line_delay) -->
        <record id="view_purchase_order_form_sid_po_line_delay" model="ir.ui.view">
            <field name="name">purchase.order.form.sid.po.line.delay</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/tree" position="attributes">
                    <attribute name="decoration-danger">sid_po_line_delay == 'more_del'</attribute>
                    <attribute name="decoration-warning">sid_po_line_delay in ('4_week_del', '2_week_del')</attribute>
                    <attribute name="decoration-info">sid_po_line_delay == '1_week_del'</attribute>
                    <attribute name="decoration-primary">sid_po_line_delay == '2_days'</attribute>
                    <attribute name="decoration-success">sid_po_line_delay in ('7_days', '14_days', '30_days',
                        'sin_ret')
                    </attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/tree" position="inside">
                    <xpath expr="//field[@name='product_id']" position="before">
                        <field name="pending_line" optional="show"/>
                        <field name="sid_po_line_delay" widget="badge" class="sid_po_delay_badge" optional="show"/>
                    </xpath>
                </xpath>
            </field>
        </record>

        <record id="view_purchase_order_line_search_sid_po_line_delay" model="ir.ui.view">
            <field name="name">purchase.order.line.search.sid_po_line_delay</field>
            <field name="model">purchase.order.line</field>
            <field name="inherit_id" ref="purchase.purchase_order_line_search"/>
            <field name="priority">16</field>
            <field name="arch" type="xml">

                <xpath expr="//search/searchpanel" position="inside">
                    <field name="sid_po_line_delay" enable_counters="1" select="multi" default_order="id asc"/>
                    <field name="pending_line" enable_counters="1"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>